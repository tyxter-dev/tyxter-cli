TYXTER_API_URL=https://api.tyxter.com
TYXTER_API_KEY=tx_sandbox_replace_me
TYXTER_WEBHOOK_FORWARD_URL=http://host.docker.internal:3000/webhooks/tyxter

# Optional. Leave blank to generate and persist a local signing secret in Docker volume state.
TYXTER_WEBHOOK_SECRET=

# Optional listener tuning.
TYXTER_CLI_STATE_DIR=
TYXTER_WEBHOOK_LIMIT=20
TYXTER_WEBHOOK_POLL_INTERVAL_MS=1000
TYXTER_WEBHOOK_EVENT_TYPE=
